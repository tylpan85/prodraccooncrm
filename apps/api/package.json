{
  "name": "@openclaw/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch --clear-screen=false --env-file=../../.env src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node --env-file=../../.env dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "@openclaw/db": "workspace:*",
    "@openclaw/recurrence": "workspace:*",
    "@openclaw/shared": "workspace:*",
    "argon2": "^0.41.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "fastify": "^5.1.0",
    "fastify-type-provider-zod": "^4.0.2",
    "jose": "^5.9.6",
    "pdfkit": "^0.18.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/pdfkit": "^0.17.6",
    "dotenv": "^16.4.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
