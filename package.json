{
  "name": "prodraccooncrm",
  "version": "0.1.0",
  "private": true,
  "description": "Raccoon CRM v2 — production rewrite",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "concurrently -n api,web -c magenta,cyan \"pnpm --filter=@openclaw/api dev\" \"pnpm --filter=@openclaw/web dev\"",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "db:reset": "pnpm --filter=@openclaw/db reset",
    "db:migrate": "pnpm --filter=@openclaw/db migrate",
    "db:seed": "pnpm --filter=@openclaw/db seed",
    "db:up": "sudo docker compose up -d postgres",
    "db:down": "sudo docker compose down",
    "dev:reset": "pnpm db:up && pnpm db:reset && pnpm dev"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.9.0",
    "concurrently": "^9.1.0",
    "typescript": "^5.6.3"
  }
}
