# Database
DATABASE_URL="postgresql://openclaw:openclaw@localhost:5433/openclaw?schema=public"

# API
API_PORT=4000
API_HOST=0.0.0.0

# Web
NEXT_PUBLIC_API_URL=http://localhost:4000

# Auth (generate with: openssl rand -hex 32)
JWT_ACCESS_SECRET=replace-me-with-long-random-string-at-least-32-chars
JWT_REFRESH_SECRET=replace-me-with-another-long-random-string-32-chars
COOKIE_SECRET=replace-me-with-a-third-long-random-string-32-chars

# Access token lifetime
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

# Node env
NODE_ENV=development
LOG_LEVEL=debug
